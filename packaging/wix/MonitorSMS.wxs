<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">
  <Package
    Name="Monitor SMS"
    Manufacturer="Internal Tools"
    Version="$(var.Version)"
    UpgradeCode="{7F2FCA2E-0E1A-4E65-90C1-7D8C5B7A01C2}"
    Scope="perUser"
  >
    <?ifdef ArpIcon?>
      <Icon Id="AppIcon" SourceFile="$(var.ArpIcon)" />
      <Property Id="ARPPRODUCTICON" Value="AppIcon" />
    <?endif?>

    <MajorUpgrade DowngradeErrorMessage="A newer version of Monitor SMS is already installed." />
    <MediaTemplate EmbedCab="yes" />
    <CustomAction
      Id="SetRuntimeDir"
      Property="MONITORSMSRUNTIMEDIR"
      Value="[LocalAppDataFolder]MonitorSMS\\runtime" />

    <StandardDirectory Id="LocalAppDataFolder">
        <Directory Id="INSTALLROOT" Name="Programs">
        <Directory Id="INSTALLFOLDER" Name="MonitorSMS">
          <Component Id="LauncherComponent" Guid="*">
            <File Id="LauncherExe" Source="$(var.LauncherExe)" KeyPath="yes">
              <Shortcut
                Id="StartMenuShortcut"
                Directory="ProgramMenuDir"
                Name="Monitor SMS"
                WorkingDirectory="INSTALLFOLDER"
                Advertise="no"
              />
              <Shortcut
                Id="DesktopShortcut"
                Directory="DesktopFolder"
                Name="Monitor SMS"
                WorkingDirectory="INSTALLFOLDER"
                Advertise="no"
              />
            </File>
            <RemoveFolder Id="RemoveProgramMenuDir" Directory="ProgramMenuDir" On="uninstall" />
          </Component>

          <Component Id="EnvComponent" Guid="*" NeverOverwrite="yes">
            <File Id="EnvFile" Source="$(var.EnvFile)" Name=".env" KeyPath="yes" />
          </Component>

        </Directory>
      </Directory>
      <Directory Id="MonitorSMSDataDir" Name="MonitorSMS">
        <Directory Id="MonitorSMSRuntimeDir" Name="runtime">
          <Component Id="RuntimeCleanupComponent" Guid="{665222B9-85DD-4C17-B2AB-C0DA7F3634C5}">
            <CreateFolder />
            <util:RemoveFolderEx Id="RemoveMonitorSMSRuntime" Property="MONITORSMSRUNTIMEDIR" On="uninstall" />
          </Component>
        </Directory>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ProgramMenuDir" Name="Monitor SMS" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />

    <Feature Id="MainFeature" Title="Monitor SMS" Level="1">
      <ComponentRef Id="LauncherComponent" />
      <ComponentRef Id="EnvComponent" />
      <ComponentRef Id="RuntimeCleanupComponent" />
    </Feature>

    <CustomAction
      Id="LaunchLauncher"
      FileRef="LauncherExe"
      ExeCommand=""
      Execute="immediate"
      Impersonate="yes"
      Return="asyncNoWait" />

    <InstallExecuteSequence>
      <Custom
        Action="SetRuntimeDir"
        Before="InstallValidate"
        Condition="REMOVE=&quot;ALL&quot;" />
      <Custom
        Action="LaunchLauncher"
        After="InstallFinalize"
        Condition="NOT Installed AND NOT UPGRADINGPRODUCTCODE" />
    </InstallExecuteSequence>
  </Package>
</Wix>
